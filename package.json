{
  "name": "kaipos",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yaml,yml}\"",
    "test": "turbo test",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "deploy:prod": "bash scripts/deploy-prod.sh",
    "deploy:prod:api": "pnpm --filter @kaipos/backend build && mkdir -p apps/frontend-admin/dist && pnpm --filter @kaipos/infra deploy:prod:api --require-approval never",
    "deploy:prod:frontend": "bash scripts/deploy-prod-frontend.sh",
    "deploy:prod:websocket": "pnpm --filter @kaipos/backend build && mkdir -p apps/frontend-admin/dist && pnpm --filter @kaipos/infra deploy:prod:websocket --require-approval never",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.5.0",
    "turbo": "^2.9.0"
  }
}
