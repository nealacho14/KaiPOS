# Local development (pnpm dev / pnpm docker:up).
# In AWS prod this is not used — CDK injects MONGO_SECRET_ARN instead and the
# backend resolves the URI from AWS Secrets Manager at cold start.
MONGO_URI=mongodb://localhost:27017/kaipos

# JWT secret for signing access tokens (local dev only; in AWS prod this comes from Secrets Manager)
JWT_SECRET=dev-only-jwt-secret-change-me

# SES email (leave unset locally to fall back to logging reset tokens instead of sending email)
# SES_SENDER_EMAIL=noreply@kaipos.com

# Base URL for password reset links (frontend URL where the reset form lives)
PASSWORD_RESET_BASE_URL=http://localhost:3000

# S3 bucket for product image uploads.
# - pnpm dev (Atlas): leave unset → POST /api/products/upload-url returns 503.
#   Or point at the local MinIO bucket using the values documented below.
# - pnpm docker:up: already wired to MinIO (kaipos-assets-dev) inside the
#   docker-compose file, so you don't need to set anything here.
# - AWS prod: injected by CDK from the AssetsStack CfnOutput.
# ASSETS_BUCKET_NAME=kaipos-assets-dev

# Custom S3 endpoint (MinIO for local dev). Triggers path-style addressing in
# the S3 client. If unset, the AWS SDK uses the default AWS endpoint.
# In pnpm docker:up this is already set to http://localhost:9000. If you run
# `pnpm dev` and want the same bucket, uncomment these:
# S3_ENDPOINT=http://localhost:9000
# AWS_ACCESS_KEY_ID=kaipos
# AWS_SECRET_ACCESS_KEY=kaiposdev123
# AWS_REGION=us-east-1

# CloudFront domain that fronts the assets bucket (used to compute the publicUrl
# returned alongside the pre-signed upload URL). Only set in AWS prod (CDK). In
# local dev with MinIO leave this unset — the service derives publicUrl from the
# pre-signed URL host instead.
# ASSETS_CDN_DOMAIN=dxxxxxxxxxxxx.cloudfront.net
