{
  "name": "@kaipos/backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "DOTENV_CONFIG_PATH=../../.env tsx watch --require dotenv/config src/index.ts",
    "build": "tsup && node -e \"require('fs').writeFileSync('dist/package.json', JSON.stringify({type:'module'}))\"",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:setup": "DOTENV_CONFIG_PATH=../../.env tsx --require dotenv/config src/db/setup.ts"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.693.0",
    "@hono/node-server": "^1.19.12",
    "@kaipos/shared": "workspace:*",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.0",
    "hono": "^4.7.0",
    "jose": "^6.2.2",
    "mongodb": "^6.12.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@kaipos/eslint-config": "workspace:*",
    "@kaipos/tsconfig": "workspace:*",
    "@types/aws-lambda": "^8.10.145",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "pino-pretty": "^13.1.3",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
