{
  "name": "kaipos",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yaml,yml}\"",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "deploy:prod": "pnpm --filter @kaipos/backend build && pnpm --filter @kaipos/frontend-admin build && pnpm --filter @kaipos/infra deploy:prod --require-approval never",
    "deploy:prod:api": "pnpm --filter @kaipos/backend build && pnpm --filter @kaipos/infra deploy:prod:api --require-approval never",
    "deploy:prod:frontend": "pnpm --filter @kaipos/frontend-admin build && pnpm --filter @kaipos/infra deploy:prod:frontend --require-approval never"
  },
  "devDependencies": {
    "turbo": "^2.9.0",
    "prettier": "^3.5.0"
  }
}
